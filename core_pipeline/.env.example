# Copy this file to .env and fill your keys

GEMINI_API_KEYS=YOUR_GEMINI_API_KEY_1,YOUR_GEMINI_API_KEY_2
GITHUB_API_KEYS=
GITHUB_API_KEY=
GROQ_API_KEYS=
GROQ_API_KEY=
MISTRAL_API_KEYS=
MISTRAL_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_API_KEY=
PREFERRED_PROVIDER=mistral

# Step 7 API translation.
# `auto` enables API translation whenever any provider key above is configured.
# Use `0` to disable provider calls and rely on local fallback behavior only.
USE_API_TRANSLATION=auto

# Provider order is comma-separated. The pipeline tries each provider until all
# OCR text fragments receive accepted English translations.
TRANSLATION_PROVIDER_ORDER=mistral,github,gemini,nvidia,openrouter,groq

# Optional model overrides.
GEMINI_TRANSLATION_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash-lite
MISTRAL_TRANSLATION_MODELS=mistral-small-latest,mistral-medium-latest,ministral-8b-latest
MISTRAL_TRANSLATION_MODEL=mistral-small-latest
GITHUB_TRANSLATION_MODELS=openai/gpt-4.1-mini,openai/gpt-4o-mini,mistral-ai/mistral-small-2503
GITHUB_TRANSLATION_MODEL=openai/gpt-4.1-mini
OPENROUTER_TRANSLATION_MODELS=openrouter/free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free
OPENROUTER_TRANSLATION_MODEL=openrouter/free
GROQ_TRANSLATION_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,openai/gpt-oss-20b,gemma2-9b-it
GROQ_TRANSLATION_MODEL=llama-3.1-8b-instant

# Optional NVIDIA NIM support. Add singular values or comma-separated plural values.
NVIDIA_API_KEYS=
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEYS=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_TRANSLATION_MODELS=meta/llama-3.1-8b-instruct,meta/llama-3.1-70b-instruct,mistralai/mistral-7b-instruct-v0.3
NVIDIA_NIM_TRANSLATION_MODEL=meta/llama-3.1-8b-instruct

API_TRANSLATION_MAX_TOKENS=1400
API_TRANSLATION_TIMEOUT_SECONDS=45
API_TRANSLATION_RETRIES_PER_PROVIDER=2

# Optional high-quality inpainting backend for difficult floating text.
# When set, Step 4 writes a crop and mask to a temp folder, runs this command,
# then reads the produced output image. Supported placeholders:
#   {image} or {input} = input crop path
#   {mask}             = 255-white inpaint mask path
#   {output}           = output crop path that the command must write
# Example shape:
# MANGA_INPAINT_COMMAND=python path\to\your_inpaint_runner.py --image "{image}" --mask "{mask}" --output "{output}"
# Built-in IOPaint adapter example, if IOPaint is installed:
# MANGA_INPAINT_COMMAND=python python/runtime/iopaint_inpaint_backend.py --input "{input}" --mask "{mask}" --output "{output}" --model migan
MANGA_INPAINT_COMMAND=
MANGA_INPAINT_COMMAND_TIMEOUT=180

# Optional dedicated manga line-art cleaner for monochrome/detail-sensitive floating text.
# Values: off (safe default), auto (use when weights exist), force (diagnostics only).
MANGA_CLEANER_BACKEND=off
MANGA_CLEANER_MODEL_DIR=models/manga_cleaner/ComfyUI/models/lama

# Optional diagnostic fallback for high-risk floating text.
# Keep this off for production because it draws English over original source text
# instead of cleaning/reconstructing the source strokes.
MANGA_SOURCE_COVER_FALLBACK=off
